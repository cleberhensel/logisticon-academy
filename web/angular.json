{
  "$schema": "./node_modules/@angular/cli/lib/config/schema.json",
  "version": 1,
  "newProjectRoot": "projects",
  "projects": {
    "logistikon-web": {
      "projectType": "application",
      "schematics": {
        "@schematics/angular:component": {
          "style": "scss",
          "standalone": true,
          "changeDetection": "OnPush"
        }
      },
      "root": "projects/logistikon-web",
      "sourceRoot": "projects/logistikon-web/src",
      "prefix": "lk",
      "architect": {
        "build": {
          "builder": "@angular-devkit/build-angular:application",
          "options": {
            "outputPath": "dist/logistikon-web",
            "index": "projects/logistikon-web/src/index.html",
            "browser": "projects/logistikon-web/src/main.ts",
            "polyfills": ["zone.js"],
            "tsConfig": "projects/logistikon-web/tsconfig.app.json",
            "assets": [
              {
                "glob": "**/*",
                "input": "projects/logistikon-web/public"
              },
              {
                "glob": "**/*",
                "input": "projects/logistikon-web/src/assets",
                "output": "/assets"
              }
            ],
            "styles": [
              "projects/logistikon-web/src/styles/styles.scss"
            ],
            "scripts": [],
            "stylePreprocessorOptions": {
              "includePaths": ["node_modules"]
            }
          },
          "configurations": {
            "production": {
              "budgets": [
                { "type": "initial", "maximumWarning": "1mb", "maximumError": "2.5mb" },
                { "type": "anyComponentStyle", "maximumWarning": "8kb", "maximumError": "16kb" }
              ],
              "outputHashing": "all"
            },
            "development": {
              "optimization": false,
              "extractLicenses": false,
              "sourceMap": true,
              "fileReplacements": [
                {
                  "replace": "projects/logistikon-web/src/environments/environment.ts",
                  "with": "projects/logistikon-web/src/environments/environment.development.ts"
                }
              ]
            }
          },
          "defaultConfiguration": "production"
        },
        "serve": {
          "builder": "@angular-devkit/build-angular:dev-server",
          "configurations": {
            "production": { "buildTarget": "logistikon-web:build:production" },
            "development": { "buildTarget": "logistikon-web:build:development" }
          },
          "defaultConfiguration": "development",
          "options": { "port": 4200 }
        },
        "extract-i18n": {
          "builder": "@angular-devkit/build-angular:extract-i18n",
          "options": { "buildTarget": "logistikon-web:build" }
        },
        "test": {
          "builder": "@angular-devkit/build-angular:karma",
          "options": {
            "polyfills": ["zone.js", "zone.js/testing"],
            "tsConfig": "projects/logistikon-web/tsconfig.spec.json",
            "assets": [
              { "glob": "**/*", "input": "projects/logistikon-web/public" }
            ],
            "styles": ["projects/logistikon-web/src/styles/styles.scss"],
            "scripts": []
          }
        }
      }
    }
  }
}
